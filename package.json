{
  "name": "@thiagofinch/mega-brain",
  "version": "2.0.0",
  "description": "AI Knowledge Management System — ingira materiais de especialistas, extraia DNA cognitivo e delibere decisões com o Conclave",
  "type": "module",
  "bin": {
    "@thiagofinch/mega-brain": "bin/cli.js",
    "mega-brain": "bin/cli.js"
  },
  "files": [
    ".claude/CLAUDE.md",
    ".claude/agents.yaml",
    ".claude/commands/",
    ".claude/hooks/",
    ".claude/jarvis/",
    ".claude/package.json",
    ".claude/rules/",
    ".claude/scripts/",
    ".claude/settings.json",
    ".claude/skills/",
    ".claude/templates/",
    ".claudeignore",
    ".gitattributes",
    ".github/CODEOWNERS",
    ".github/ISSUE_TEMPLATE/",
    ".github/PULL_REQUEST_TEMPLATE.md",
    ".github/assets/",
    ".github/workflows/",
    ".gitignore",
    ".gitleaks.toml",
    "QUICK-START.md",
    "agents/_registry/ecosystem-registry.yaml",
    "agents/README.md",
    "agents/_templates/",
    "agents/constitution/",
    "agents/system/conclave/",
    "bin/",
    "engine/__init__.py",
    "engine/glossary/",
    "engine/intelligence/",
    "engine/jarvis/",
    "engine/patterns/",
    "engine/schemas/",
    "engine/tasks/",
    "engine/templates/README.md",
    "engine/templates/agents/",
    "engine/templates/debates/",
    "engine/templates/logs/",
    "engine/templates/phases/",
    "engine/workflows/",
    "docs/api-keys-guide.md",
    "docs/checklists/",
    "docs/integration-points.md",
    "docs/prompts/",
    "docs/quick-start.md",
    "docs/templates/phase5/",
    "knowledge/external/dna/.gitkeep",
    "knowledge/external/dossiers/persons/.gitkeep",
    "knowledge/external/dossiers/system/.gitkeep",
    "knowledge/external/dossiers/themes/.gitkeep",
    "knowledge/external/playbooks/.gitkeep",
    "knowledge/external/sources/.gitkeep",
    "logs/.gitkeep",
    "logs/README.md",
    "requirements.txt",
    "workspace/workspace.yaml",
    "workspace/structure.yaml",
    "workspace/relationships.yaml",
    "workspace/_templates/",
    "workspace/config/",
    "workspace/providers/",
    "system/02-JARVIS-SOUL.md",
    "system/03-JARVIS-DNA.yaml"
  ],
  "scripts": {
    "start": "node bin/mega-brain.js",
    "install-wizard": "node bin/mega-brain.js install",
    "validate": "node bin/mega-brain.js validate",
    "validate:layers": "node bin/validate-package.js",
    "validate:json": "python3 engine/intelligence/validation/validate_json_integrity.py",
    "lint": "ruff check engine/ .claude/hooks/",
    "lint:fix": "ruff check engine/ .claude/hooks/ --fix",
    "format": "ruff format engine/ .claude/hooks/",
    "test": "python3 -m pytest tests/python/ -v",
    "test:coverage": "python3 -m pytest tests/python/ -v --cov=engine/intelligence --cov-report=term-missing",
    "postinstall": "node bin/install-hooks.js",
    "prepublishOnly": "node bin/pre-publish-gate.js"
  },
  "keywords": [
    "ai",
    "knowledge-management",
    "agents",
    "jarvis",
    "mind-cloning",
    "playbooks",
    "conclave",
    "rag"
  ],
  "author": "thiagofinch",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "boxen": "^7.1.1",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "fs-extra": "^11.3.4",
    "gradient-string": "^2.0.2",
    "inquirer": "^9.3.8",
    "ora": "^7.0.1",
    "turndown": "^7.2.4",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "execa": "^9.6.1",
    "js-yaml": "^4.1.1"
  }
}
