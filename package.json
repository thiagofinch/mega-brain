  "scripts": {
    "start": "node bin/mega-brain.js",
    "install-wizard": "node bin/mega-brain.js install",
    "validate": "node bin/mega-brain.js validate",
    "validate:layers": "node bin/validate-package.js",
    "validate:json": "python3 core/intelligence/validation/validate_json_integrity.py",
    "lint": "ruff check core/ .claude/hooks/",
    "lint:fix": "ruff check core/ .claude/hooks/ --fix",
    "format": "ruff format core/ .claude/hooks/",
    "test": "python3 -m pytest tests/python/ -v",
    "test:coverage": "python3 -m pytest tests/python/ -v --cov=core/intelligence --cov-report=term-missing",
    "postinstall": "node bin/install-hooks.js",
    "prepublishOnly": "node bin/pre-publish-gate.js"
  },
  "keywords": [
    "ai",
    "knowledge-management",
    "agents",
