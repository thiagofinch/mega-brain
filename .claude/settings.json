{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/session_start.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/skill_indexer.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/inbox_age_alert.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/session_index.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/session_autosave_v2.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/session-source-sync.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/skill_router.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/quality_watchdog.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/user_prompt_submit.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/memory_hints_injector.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/enforce_plan_mode.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/memory_updater.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pending_tracker.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/claude_md_guard.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/creation_validator.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/directory_contract_guard.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre_commit_audit.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/agent_deprecation_guard.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/post_tool_use.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/enforce_dual_location.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pipeline_checkpoint.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/agent_creation_trigger.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/agent_index_updater.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/claude_md_agent_sync.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/agent_memory_persister.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 '.claude/hooks/memory_capture.py'",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/post_batch_cascading.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pipeline_phase_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pipeline_orchestrator.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/stop_hook_completeness.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/session_end.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/ralph_wiggum.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/continuous_save.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/memory_manager_stop.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/session_index.py",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm:-rf *)",
      "Bash(rm:* -rf *)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(*.env)",
      "Write(*.env)",
      "Edit(*.env)",
      "Read(*/.env)",
      "Write(*/.env)",
      "Edit(*/.env)",
      "Read(~/.ssh/*)",
      "Write(~/.ssh/*)",
      "Edit(~/.ssh/*)"
    ]
  }
}
