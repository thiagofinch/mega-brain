      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(*--no-verify*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Read(*.env)",
      "Write(*.env)",
      "Edit(*.env)",
      "Read(*/.env)",
      "Write(*/.env)",
      "Edit(*/.env)",
      "Read(~/.ssh/*)",
      "Write(~/.ssh/*)",
      "Edit(~/.ssh/*)",
      "Read(./private/**)"
    ]
  },
  "deliberation_gate": {
