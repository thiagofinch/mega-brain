# ==============================================================================
# Mega Brain - Configuracao de ambiente
# ==============================================================================
# Copie este arquivo para .env e preencha com as suas chaves:
#     cp .env.example .env
#
# Regras:
#   - O .env e a UNICA fonte de credenciais. Nunca escreva chaves no codigo.
#   - O .env ja esta no .gitignore e NUNCA deve ser versionado.
#   - Preencha apenas os placeholders abaixo (nenhum valor real vem neste arquivo).
#
# Guia passo a passo de cada chave: docs/api-keys-guide.md
# ==============================================================================


# ------------------------------------------------------------------------------
# OBRIGATORIAS
# ------------------------------------------------------------------------------

# Anthropic (Claude) — LLM nucleo do sistema.
# Toda a inteligencia roda aqui: processamento, agentes, Conclave e extracao de DNA.
# Obrigatoria. Obtenha em: https://console.anthropic.com/  (API Keys > Create Key)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI — transcricao de audio/video (Whisper) e embeddings do RAG.
# E o provedor canonico de embeddings da busca semantica (text-embedding-3-large).
# Obrigatoria para transcricao automatica e para indexar/consultar o RAG.
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini — extracao e analise visual de video (Speaker Visual Gate).
# Identifica quem fala e o assunto em videos durante a ingestao.
# Obrigatoria para ingerir VIDEO. O sistema le GEMINI_API_KEY primeiro e,
# se ausente, GOOGLE_API_KEY (defina apenas uma das duas).
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------------------------
# RECOMENDADA
# ------------------------------------------------------------------------------

# Voyage AI — embeddings alternativos para o RAG.
# Recomendada para quem quer um provedor de embeddings dedicado alem do OpenAI.
# Opcional: o RAG funciona com OPENAI_API_KEY sozinho.
# Obtenha em: https://dash.voyageai.com/  (API Keys > Create new API key)
# VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------------------------
# OPCIONAIS (voz e transcricao avancada)
# ------------------------------------------------------------------------------

# ElevenLabs — voz do JARVIS (Text-to-Speech). Opcional.
# So necessaria se voce ativar a interacao por voz.
# Obtenha em: https://elevenlabs.io/  (Profile + API key)
# ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deepgram — Speech-to-Text para o JARVIS (ouvir comandos por voz). Opcional.
# Obtenha em: https://console.deepgram.com/  (API Keys > Create a New API Key)
# DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AssemblyAI — transcricao de audio/video na nuvem com diarizacao de falantes.
# Opcional: alternativa de transcricao ao Whisper local. Identifica "quem falou o que".
# Obtenha em: https://www.assemblyai.com/  (Dashboard > API Keys)
# ASSEMBLYAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
