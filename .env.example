#==================================
# Mega Brain - Environment Variables
#==================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#==================================

# Owner Identity (used for dual-routing founder insights to personal bucket)
MEGA_BRAIN_OWNER_NAME=Your Full Name
MEGA_BRAIN_OWNER_EMAIL=your@email.com

# ElevenLabs - Text-to-Speech (https://elevenlabs.io)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Anthropic - Claude AI (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Deepgram - Speech-to-Text (https://deepgram.com)
DEEPGRAM_API_KEY=your-deepgram-api-key

# VAPI - Voice AI Platform (https://vapi.ai)
VAPI_API_KEY=your-vapi-api-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_VOICE_ID_V5_BR=your-vapi-voice-id
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# ElevenLabs Voice IDs (optional - for voice cloning features)
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
ELEVENLABS_NARRATOR_VOICE_ID=your-narrator-voice-id
ELEVENLABS_TERMINAL_VOICE_ID=your-terminal-voice-id

# Google OAuth - Drive/Sheets access
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# MCP Services
N8N_API_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your-n8n-api-key
CLICKUP_PERSONAL_TOKEN=your-clickup-token
MIRO_TOKEN=your-miro-token
FIGMA_API_KEY=your-figma-api-key
NOTION_TOKEN=your-notion-token

# Supabase - Email Validation (https://supabase.com)
# Dashboard: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Premium Distribution - GitHub PAT (contents:read on mega-brain-premium)
PREMIUM_REPO_TOKEN=your-github-pat-for-premium-repo

# RAG - Voyage AI Embeddings (https://dash.voyageai.com)
VOYAGE_API_KEY=your-voyage-api-key

# Read.ai - Meeting Transcript Harvester
READ_AI_EMAIL=your-read-ai-email
READ_AI_PASSWORD=your-read-ai-password
READ_AI_API_URL=https://api.read.ai/mcp
READ_AI_COMPANY_NAME=Your Company
READ_AI_COMPANY_DOMAINS=yourcompany.com,yourcompany.com.br
READ_AI_COMPANY_KEYWORDS=yourcompany,your company
READ_AI_TAG_PREFIX=MEET
READ_AI_INGESTION_BATCH=10
READ_AI_GARDENER_TRIGGER=5
READ_AI_PAGE_SIZE=50
