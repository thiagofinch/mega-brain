# ==============================================================================
# MEGA BRAIN - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# Run 'npx mega-brain-ai setup' to configure interactively.
# ==============================================================================


# ==============================================================================
# OWNER IDENTITY
# ==============================================================================
# Used by the pipeline router and scope classifier to distinguish founder
# content from external/business content. Without these, meeting transcripts
# cannot be routed to the personal knowledge bucket.

MEGA_BRAIN_OWNER_NAME=
MEGA_BRAIN_OWNER_EMAIL=


# ==============================================================================
# REQUIRED -- pipeline will not work without this
# ==============================================================================

# OpenAI Whisper -- video/audio transcription
# Essential for /ingest with YouTube videos and audio files.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ==============================================================================
# RECOMMENDED -- full power, but system works without these
# ==============================================================================

# Voyage AI -- semantic embeddings for RAG search
# Without this, semantic search uses BM25 only (keyword-based, no vectors).
# Get yours at: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=


# ==============================================================================
# OPTIONAL -- convenience and integration features
# ==============================================================================

# --- Meeting Transcript Sources -----------------------------------------

# Fireflies.ai -- meeting transcript sync (GraphQL API)
# Polls for new transcripts and routes them to knowledge buckets.
# Get yours at: https://app.fireflies.ai/integrations (API key section)
FIREFLIES_API_KEY=
# FIREFLIES_GRAPHQL_URL=https://api.fireflies.ai/graphql
# FIREFLIES_TAG_PREFIX=MEET
# FIREFLIES_POLL_INTERVAL=5
# FIREFLIES_PAGE_SIZE=50

# Read.ai -- meeting transcript harvester (MCP-based)
# Used with the Read.ai MCP server for transcript ingestion.
# READ_AI_EMAIL=
# READ_AI_PASSWORD=
# READ_AI_API_URL=https://api.read.ai/mcp
# READ_AI_COMPANY_NAME=
# READ_AI_COMPANY_DOMAINS=example.com,example.com.br
# READ_AI_COMPANY_KEYWORDS=example,example inc
# READ_AI_TAG_PREFIX=MEET
# READ_AI_INGESTION_BATCH=10
# READ_AI_GARDENER_TRIGGER=5
# READ_AI_PAGE_SIZE=50

# Read.ai OAuth (alternative to email/password, for API access)
# READ_AI_CLIENT_ID=
# READ_AI_CLIENT_SECRET=
# READ_AI_AUTH_URL=https://authn.read.ai/oauth2/auth
# READ_AI_TOKEN_URL=https://authn.read.ai/oauth2/token

# --- N8N Automation -----------------------------------------------------

# N8N -- webhook and workflow automation
# Used for notification hub and workflow triggers.
# Dashboard: https://your-instance.app.n8n.cloud
N8N_API_URL=
N8N_API_KEY=
# N8N_WEBHOOK_URL=

# --- Google Services ----------------------------------------------------

# Google OAuth -- import transcriptions from Google Drive
# Without these, download files manually to inbox/.
# Setup at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Gemini -- optional MCE extraction enhancer
# Falls back gracefully when not set (uses Claude-only extraction).
# Get yours at: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=

# --- Collaboration Tools ------------------------------------------------

# ClickUp -- project management integration
# CLICKUP_PERSONAL_TOKEN=

# Miro -- visual collaboration
# MIRO_TOKEN=

# Figma -- design tool integration
# FIGMA_API_KEY=

# Notion -- knowledge management integration
# NOTION_TOKEN=

# --- Voice and Speech ---------------------------------------------------

# Anthropic -- only needed for standalone Python scripts outside Claude Code
# Not required when using Claude Code (Max/Pro subscription covers it).
# ANTHROPIC_API_KEY=

# ElevenLabs -- text-to-speech (https://elevenlabs.io)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_NARRATOR_VOICE_ID=
# ELEVENLABS_TERMINAL_VOICE_ID=

# Deepgram -- speech-to-text fallback (https://deepgram.com)
# Cloud fallback when local GPU is unavailable.
# DEEPGRAM_API_KEY=

# AssemblyAI -- speaker diarization (https://www.assemblyai.com)
# Used by voice_diarizer.py for speaker identification.
# ASSEMBLYAI_API_KEY=

# VAPI -- voice AI platform (https://vapi.ai)
# VAPI_API_KEY=
# VAPI_ASSISTANT_ID=
# VAPI_VOICE_ID_V5_BR=
# VAPI_WEBHOOK_SECRET=

# --- Database and Infrastructure ---------------------------------------

# Supabase -- email validation (https://supabase.com)
# Dashboard: Settings -> API
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_KEY=

# --- Premium Distribution ----------------------------------------------

# GitHub PAT -- required for premium content install (contents:read)
# PREMIUM_REPO_TOKEN=

# --- Pipeline Tuning ---------------------------------------------------

# Entity Resolution -- maps alternate names to canonical slugs
# Format: name:slug,name:slug (comma-separated pairs)
# Example: MEGA_BRAIN_ENTITY_ALIASES=john doe:john-doe,jdoe:john-doe
MEGA_BRAIN_ENTITY_ALIASES=

# Source Code Map -- short codes for each expert/person
# Format: slug:CODE,slug:CODE (comma-separated pairs)
# Example: MEGA_BRAIN_SOURCE_CODES=john-doe:JD,jane-smith:JS
MEGA_BRAIN_SOURCE_CODES=

# Company Keywords -- additional keywords for scope classification
# Used by scope_classifier.py alongside READ_AI_COMPANY_KEYWORDS.
# MEGA_BRAIN_COMPANY_KEYWORDS=

# Course-to-Folder Map -- maps course names to inbox folder names
# Format: JSON string
# Example: MEGA_BRAIN_COURSE_MAP={"Course Name": "FOLDER_NAME"}
MEGA_BRAIN_COURSE_MAP=

# Batch processing -- minimum files to trigger auto-batch
# BATCH_MIN_FILES=3

# Inbox base path override (for classify_unknown.py)
# MEGA_BRAIN_INBOX=

# --- GitHub Organization (for multi-repo setups) -----------------------

# MEGA_BRAIN_GH_ORG=
# MEGA_BRAIN_GH_REPO=mega-brain-premium
# MEGA_BRAIN_GH_REPO_L1=mega-brain
# MEGA_BRAIN_GH_REPO_L2=
# MEGA_BRAIN_GH_REPO_L3=

# Google Sheets -- spreadsheet ID for de-para validation
# MEGA_BRAIN_SPREADSHEET_ID=
